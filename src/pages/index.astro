---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '밀리트래커 - 군적금 수령액 자동 계산 앱',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
      variant: 'primary',
      text: 'Google Play 다운로드',
      href: 'https://play.google.com/store/apps/details?id=com.sungs.militracker',
      target: '_blank',
      icon: 'tabler:download',
      },
      { text: '주요 기능', href: '#features' },
    ]}
    image={{ src: '~/assets/images/853shots_so.png', alt: '밀리트래커 대시보드 - 예상 총 수령액과 은행별 납입 현황' }}
  >
    <Fragment slot="title">
      내 군적금, 전역 때 얼마 받을까? <br />
      <span class="text-accent dark:text-white">밀리트래커</span>
    </Fragment>

    <Fragment slot="subtitle">
      복무 기간 동안 받게 될 원리금과 매칭지원금을 자동으로 계산해드립니다.<br/>
      복잡한 엑셀 정리는 그만, 한 화면에서 전역까지의 자산을 확인하세요.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Key Features"
    title="밀리트래커가 제공하는 핵심 기능"
    subtitle="여러 은행에 분산된 군적금, 매칭지원금, 우대금리까지. <br> 흩어진 정보를 한 번에 모아 정확한 전역 수령액을 보여드립니다."
    items={[
      {
        title: '💰 한눈에 보는 예상 총 수령액',
        description:
          '여러 은행에 가입한 적금의 원금, 이자, 매칭지원금을 모두 합산해 전역 시점의 실수령액을 한 번에 보여드립니다.',
        icon: 'tabler:wallet',
      },
      {
        title: '🏦 은행별 납입 현황 관리',
        description:
          'KB국민·IBK기업·NH농협 등 가입한 모든 적금의 월 납입액, 누적 납입액, 예상 이자를 카드 형태로 깔끔하게 정리해드립니다.',
        icon: 'tabler:building-bank',
      },
      {
        title: '🎁 매칭지원금 계산',
        description:
          '입력하신 추가 금리에 따라 본인 납입액 대비 받게 될 추가 지원금을 자동으로 계산합니다. 직접 계산할 필요가 없습니다.',
        icon: 'tabler:gift',
      },
      {
        title: '⏰ D-day와 마지막 달 납입 알림',
        description:
          '전역까지 남은 일수를 항상 표시해드리고, 마지막 달 납입일에 맞춰 알림을 보내드려 놓치지 않게 도와드립니다.',
        icon: 'tabler:bell',
      },
      {
        title: '📈 최신 우대금리 즉시 반영',
        description:
          '은행별 기본금리가 변경되면 앱이 자동으로 최신 정보를 받아옵니다. 본인 우대금리는 설정에서 직접 입력해 정밀한 수령액을 확인하세요.',
        icon: 'tabler:chart-line',
      },
      {
        title: '🪖 현역·사회복무요원 모두 지원',
        description:
          '복무 형태와 입대일·전역일에 맞춰 잔여 복무 기간을 정확히 계산합니다. 복무 중인 누구라도 부담 없이 사용할 수 있습니다.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
  actions={[
    {
      variant: 'primary',
      text: 'Google Play에서 다운로드',
      href: 'https://play.google.com/store/apps/details?id=com.sungs.militracker',
      target: '_blank',
      icon: 'tabler:download',
    },
  ]}
>
  <Fragment slot="title">
    지금 바로 <span class="text-accent dark:text-white sm:whitespace-nowrap">밀리트래커</span>를 시작하세요
  </Fragment>

  <Fragment slot="subtitle">
    내 군적금 수령액이 궁금하다면 더 이상 미루지 마세요.<br class="hidden md:inline" />
    복무 기간의 자산을 한눈에 확인하는 경험, 지금 시작해보세요.
  </Fragment>
</CallToAction>
</Layout>
